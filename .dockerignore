# ============================================================================
# .dockerignore for the development / test image.
#
# Unlike a production image, the dev image deliberately INCLUDES tests/,
# simulator_tests/, the Dockerfile(s), docker-compose.yml, docs/ and conf/ so
# the test suite can run inside the container. We only exclude secrets, virtual
# environments, caches and build noise.
# ============================================================================

# Version control
.git
.gitignore

# Python caches / build artifacts
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/
.mypy_cache/
.pytest_cache/
.ruff_cache/
htmlcov/
.coverage
.coverage.*

# Virtual environments
env/
venv/
.venv/
.pal_venv/
ENV/
env.bak/
venv.bak/

# Secrets - never copy real credentials into the image
.env
.env.local
*.key
*.pem
*.p12
*.pfx
*.crt
*.csr
secrets/
private/

# Logs
logs/*.log*
*.log

# OS / IDE noise
.DS_Store
Thumbs.db
.idea/
*.swp
*.swo
